{% template main %}

<script>var __oss = {{ items | json }};</script>

{%- if view == 1 -%}{%- assign title_cls = "title--xlarge" -%}{%- assign desc_clamp = 5 -%}
{%- elsif view == 2 -%}{%- assign title_cls = "title--large" -%}{%- assign desc_clamp = 4 -%}
{%- elsif view == 3 -%}{%- assign title_cls = "title--large" -%}{%- assign desc_clamp = 3 -%}
{%- else -%}{%- assign title_cls = "title--small" -%}{%- assign desc_clamp = 3 -%}{%- endif -%}

{%- capture text_block -%}
  {% unless view == 4 %}<span class="label label--small">Open-Source Spotlight</span>{% endunless %}
  <span class="oss-title title {{ title_cls }}" data-clamp="2"></span>
  <span class="oss-desc description{% if view == 1 %} description--large{% endif %}" data-clamp="{{ desc_clamp }}"></span>
  <div class="flex gap--small">
    <span class="oss-year label label--small label--underline"></span>
    <span class="oss-domain label label--small"></span>
  </div>
{%- endcapture -%}

{% if view == 1 or view == 2 %}
  <div class="grid {% if view == 1 %}grid--cols-5{% else %}grid--cols-3{% endif %} gap--large h--full">
    <div class="{% if view == 1 %}col--span-3{% else %}col--span-2{% endif %} flex flex--col flex--left flex--top gap--small">{{ text_block }}</div>
    <div class="oss-figure {% if view == 1 %}col--span-2{% else %}col--span-1{% endif %} flex flex--col flex--center">
      <img class="oss-image image image-dither image--contain h--full" alt="">
    </div>
  </div>
{% elsif view == 3 %}
  <div class="layout layout--col layout--top gap--small h--full">
    <div class="flex flex--col flex--left flex--top gap--small">{{ text_block }}</div>
    <div class="oss-figure flex flex--center stretch-x h--[150px]">
      <img class="oss-image image image-dither image--contain h--full" alt="">
    </div>
  </div>
{% else %}
  <div class="flex flex--col flex--left flex--top gap--small h--full">{{ text_block }}</div>
{% endif %}

<div class="title_bar">
  {%- capture svg_logo -%}<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="#f8654b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="4 7 9 12 4 17"/><line x1="12" y1="17" x2="20" y2="17"/></svg>{%- endcapture -%}
  <img class="image" src="data:image/svg+xml;base64,{{ svg_logo | base64_encode }}" alt="OSS">
  <span class="title">{{ trmnl.plugin_settings.instance_name }}</span>
</div>

<script>
(function () {
  var views = Array.prototype.slice.call(document.querySelectorAll('.view'));
  var script = document.currentScript;
  var host = views.filter(function (v) { return v.contains(script); })[0] || document.body;
  var idx = views.indexOf(host);
  if (idx < 0) idx = 0;
  var pool = (typeof __oss !== 'undefined' && __oss) ? __oss : [];
  var p = pool.length ? pool[idx % pool.length] : {};

  function set(sel, val) {
    var el = host.querySelector(sel);
    if (el) el.textContent = val || '';
  }
  set('.oss-title', p.title);
  set('.oss-desc', p.description);
  set('.oss-year', p.year ? 'Since ' + p.year : '');
  set('.oss-domain', p.domain);

  var fig = host.querySelector('.oss-figure');
  var img = host.querySelector('.oss-image');
  if (img) {
    if (p.image) { img.setAttribute('src', p.image); }
    else if (fig) { fig.parentNode.removeChild(fig); }
  }
})();
</script>

{% endtemplate %}
